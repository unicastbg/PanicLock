<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Master toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Shake Detection"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <Switch
                android:id="@+id/switchMaster"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:thumbTint="@color/switch_thumb"
                android:trackTint="@color/switch_track"/>

        </LinearLayout>

        <!-- Sensitivity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sensitivity"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSensitivityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medium"
                    android:textColor="#00D4FF"/>

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekBarSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="4"
                android:progress="2"
                android:progressTint="#00D4FF"
                android:thumbTint="#00D4FF"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="High"
                    android:textColor="#8B949E"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low"
                    android:textColor="#8B949E"
                    android:textSize="12sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- On-trigger actions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ON TRIGGER"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="8dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lock Screen"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>
                <Switch
                    android:id="@+id/switchLock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Silent Mode"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>
                <Switch
                    android:id="@+id/switchSilent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable GPS"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>
                <Switch
                    android:id="@+id/switchGps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Mobile Data"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>
                <Switch
                    android:id="@+id/switchMobileData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kill Apps on Trigger"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>
                <Switch
                    android:id="@+id/switchKillApps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnManageKillList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="8dp"
                android:text="Manage App Kill List"
                android:backgroundTint="#0D1117"
                android:textColor="#00D4FF"/>

        </LinearLayout>

        <!-- Panic Alarm -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PANIC ALARM"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Strobe + Alarm on Trigger"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

                <Switch
                    android:id="@+id/switchPanicAlarm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPanicDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Duration"
                    android:textColor="#8B949E"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvPanicDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30s"
                    android:textColor="#00D4FF"
                    android:layout_marginEnd="8dp"/>

                <SeekBar
                    android:id="@+id/seekBarPanicDuration"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:max="4"
                    android:progress="1"
                    android:progressTint="#00D4FF"
                    android:thumbTint="#00D4FF"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Notification -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NOTIFICATION"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hide Notification Icon"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

                <Switch
                    android:id="@+id/switchHideNotification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hides the status bar icon. Notification remains in shade."
                android:textColor="#3A3F47"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Battery -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BATTERY"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stop Service Below"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/tvBatteryThreshold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off"
                    android:textColor="#00D4FF"
                    android:layout_marginEnd="8dp"/>

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekBarBattery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="6"
                android:progress="0"
                android:progressTint="#00D4FF"
                android:thumbTint="#00D4FF"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Off"
                    android:textColor="#3A3F47"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30%"
                    android:textColor="#3A3F47"
                    android:textSize="12sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Security -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SECURITY"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fake Power Menu"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

                <Switch
                    android:id="@+id/switchFakePowerMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Replaces power menu with a fake one that does nothing."
                android:textColor="#3A3F47"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Telegram Bot -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TELEGRAM BOT"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <!-- Enable toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Telegram Bot"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

                <Switch
                    android:id="@+id/switchTelegram"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track"/>

            </LinearLayout>

            <!-- Collapsed summary — shown when credentials are saved -->
            <LinearLayout
                android:id="@+id/layoutTelegramSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvTelegramSummary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bot configured ✓"
                    android:textColor="#00D4FF"
                    android:textSize="13sp"/>

                <Button
                    android:id="@+id/btnEditTelegram"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit"
                    android:backgroundTint="#0D1117"
                    android:textColor="#00D4FF"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Full config — shown when editing or not yet configured -->
            <LinearLayout
                android:id="@+id/layoutTelegramConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bot Token"
                    android:textColor="#8B949E"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etBotToken"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="123456789:ABCdef..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#3A3F47"
                    android:background="#0D1117"
                    android:padding="12dp"
                    android:inputType="text"
                    android:singleLine="true"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chat ID"
                    android:textColor="#8B949E"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etChatId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="123456789"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#3A3F47"
                    android:background="#0D1117"
                    android:padding="12dp"
                    android:inputType="number"
                    android:singleLine="true"/>

                <Button
                    android:id="@+id/btnTestTelegram"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Save &amp; Test Connection"
                    android:backgroundTint="#0D1117"
                    android:textColor="#00D4FF"/>

            </LinearLayout>

            <!-- Location interval — always visible when Telegram enabled -->
            <LinearLayout
                android:id="@+id/layoutLocationInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Location Update Interval"
                    android:textColor="#8B949E"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvLocationInterval"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Off"
                        android:textColor="#00D4FF"
                        android:textSize="14sp"/>

                    <SeekBar
                        android:id="@+id/seekBarLocationInterval"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:max="6"
                        android:progress="0"
                        android:progressTint="#00D4FF"
                        android:thumbTint="#00D4FF"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Off"
                        android:textColor="#3A3F47"
                        android:textSize="11sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 hour"
                        android:textColor="#3A3F47"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- About -->
        <Button
            android:id="@+id/btnAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="About PanicLock"
            android:backgroundTint="#161B22"
            android:textColor="#8B949E"/>

        <!-- Bottom padding -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp"/>

    </LinearLayout>

</ScrollView>
